# Copy to .env and fill. All env access goes through app/config.py:Settings (rule 6).

# Cassette mode: replay (default, $0, offline) | record | live. record/live cost money (rule 4).
LLM_MODE=replay

# Role -> tier resolution (tiers map to dated snapshots in llm-tiers.yaml).
TRIAGE_TIER=cheap
JUDGE_TIER=smart

# OpenAI access (only needed for record/live). LiteLLM SDK reads these via Settings.
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# MLflow control-plane backend (Docker Compose service).
MLFLOW_TRACKING_URI=http://localhost:5050
