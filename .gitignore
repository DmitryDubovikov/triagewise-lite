# artifact is eval/outputs.json; these are not it.
eval/.results.json
eval/.record-results.json
eval/.promptfoo-cache/

# Env / secrets
.env

# MLflow / Docker local state (mounted volumes)
mlflow-data/
# Stray local sqlite if a client ever runs against the default URI instead of Settings.
/mlflow.db
/mlruns/

# Access-layer SLO log (runtime artifact, iter 3)
logs/
